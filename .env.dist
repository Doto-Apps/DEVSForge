# Front
VITE_API_BASE_URL=http://localhost:3000/

# Back - Database
DB_HOST=db
DB_USER=devsforge
DB_PASSWORD=test123
DB_NAME=devsforge
DB_PORT=5432
DB_DEBUG_QUERIES=0

# Back - Server
#PORT=3000

# Back - Authentication (REQUIRED - no defaults)
JWT_SECRET=your_jwt_secret
REFRESH_TOKEN_SECRET=your_refresh_token_secret

# Back - Logging
#LOG_DIR=/tmp/sim-logs/
#LOG_MODE=all

# Back - Kafka
KAFKA_ADDRESS=kafka:9092

# Back - Simulator
#SIMULATOR_COORDINATOR_PATH=/app/simulator/coordinator
#SIMULATOR_CMD=
#SIMULATOR_ADDR=simulator:8080
#SIMULATOR_MODE=async

# Coordinator - Simulator
#SIMULATOR_PORT=8080

# Coordinator/Runner - Paths
#PATHS_RUNNER_CMD=/opt/devsforge/devsforge-runner
#PATHS_SIM_ROOT=/app
#PATHS_WRAPPERS_DIR=/opt/devsforge/wrappers

# Coordinator - Kafka (optional override)
#KAFKA_TOPIC=

# Runner - Java (optional)
#JAVA_HOME=
