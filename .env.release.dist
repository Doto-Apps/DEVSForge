DEVSFORGE_IMAGE_TAG=latest

# Backend runtime
PORT=3000
NODE_ENV=production
CLIENT_URL=http://localhost:5173
SECRET=change_me
JWT_SECRET=change_me
REFRESH_TOKEN_SECRET=change_me

# Database connection used by backend
DB_HOST=db
DB_PORT=5432
DB_USER=devsforge
DB_PASSWORD=test123
DB_NAME=devsforge

# PostgreSQL container bootstrap
POSTGRES_USER=devsforge
POSTGRES_PASSWORD=test123
POSTGRES_DB=devsforge

# Kafka + simulator runtime
KAFKA_ADDRESS=kafka:9092
COORDINATOR_PATH=/app/simulator/coordinator

# Optional default AI settings
AI_API_URL=https://api.openai.com/v1
AI_API_KEY=replace_with_real_key
AI_MODEL=gpt-4.1-mini
