FROM golang:1.25.4

WORKDIR /app

RUN go install github.com/cosmtrek/air@v1.61.2

# Install Python and grpc dependencies for Python models
RUN apt-get update && apt-get install -y python3 python3-pip && \
    pip3 install --break-system-packages grpcio grpcio-tools protobuf

WORKDIR /app/back
CMD ["air", "-c", "/app/back/.air.toml"]