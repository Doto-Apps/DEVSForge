package main

import (
	"fmt"
	"modeling"
)

// DumbModel : modèle DEVS avec un comportement volontairement "de merde".
type DumbModel struct {
	modeling.Atomic // On embed l'Atomic pour récupérer HoldIn, Passivate, etc.
	counter         int
}

// NewModel est la fonction qu'attend ton bootstrap.
// Elle renvoie un modeling.Atomic initialisé.
func NewModel() modeling.Atomic {
	// NewAtomic crée un Atomic de base avec phase "passive" et sigma infini.
	base := modeling.NewAtomic("DumbModel")

	m := &DumbModel{
		Atomic:  base,
		counter: 0,
	}

	// On met le modèle tout de suite en "active" avec sigma = 1.0
	m.HoldIn("active", 1.0)
	return m
}

// DeltInt : transition interne
// Ici, on incrémente juste un compteur et on se réactive à chaque fois,
// jusqu'à 5 fois, puis on se passivise. Pas de logique utile → c'est naze.
func (m *DumbModel) DeltInt() {
	m.counter++
	fmt.Println("[DumbModel] DeltInt, counter =", m.counter)

	if m.counter >= 5 {
		// au bout de 5 events, on arrête tout
		m.Passivate()
	} else {
		// sinon on reste "active" et on reprogramme un événement dans 1.0
		m.HoldIn("active", 1.0)
	}
}

// DeltExt : transition externe
// Comportement débile : on ignore complètement les inputs et
// on "mange" juste le temps écoulé avec Continue.
func (m *DumbModel) DeltExt(e float64) {
	fmt.Println("[DumbModel] DeltExt, e =", e, "(on ignore tout)")
	// On décrémente sigma de e, grâce à la méthode de base
	m.Continue(e)
}

// DeltCon : transition confluent
// Comportement ultra simpliste : on considère que l'interne gagne toujours.
func (m *DumbModel) DeltCon(e float64) {
	fmt.Println("[DumbModel] DeltCon, e =", e, "(on fait juste DeltInt)")
	m.DeltInt()
}

// Lambda : fonction de sortie
// Comportement pourri : on ne génère aucun événement DEVS,
// on fait juste un log sur stdout.
func (m *DumbModel) Lambda() {
	fmt.Println("[DumbModel] Lambda, phase =", m.GetPhase(), "counter =", m.counter)
	// Pas de ports, pas de messages → parfait pour un comportement de test "nul".
}
